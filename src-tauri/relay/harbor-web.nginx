server {
    listen 80;
    listen [::]:80;
    server_name app.harborstremio.com;

    root /var/www/harbor-web;
    index index.html;

    add_header X-Robots-Tag "noindex, nofollow, noarchive, nosnippet, noimageindex" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer" always;

    auth_basic "Harbor (private alpha)";
    auth_basic_user_file /etc/nginx/harbor-web.htpasswd;

    location ^~ /.well-known/acme-challenge/ {
        auth_basic off;
        root /var/www/html;
    }

    location = /robots.txt {
        auth_basic off;
        return 200 "User-agent: *\nDisallow: /\n";
    }

    location ~ ^/api-proxy/([^/]+)(/.*)$ {
        auth_basic off;

        set $proxy_target_host $1;
        set $proxy_target_path $2$is_args$args;

        if ($proxy_target_host !~ ^(api\.torbox\.app|api\.knaben\.org|nyaa\.si|rutor\.info|apibay\.org|api\.real-debrid\.com|api\.alldebrid\.com|debrid-link\.com|www\.premiumize\.me|bitsearch\.to|eztv\.re|yts\.mx|torrentio\.strem\.fun|stremio\.torbox\.app|v3-cinemeta\.strem\.io|opensubtitles-v3\.strem\.io|opensubtitles\.strem\.io|opensubtitles\.stremio\.homes|1337x\.bz|.+\.elfhosted\.com|.+\.strem\.fun|.+\.strem\.io|.+\.stremio\.homes|.+\.baby-beamup\.club|.+\.workers\.dev|.+\.debridio\.com|.+\.code\.run|.+\.fly\.dev|.+\.onrender\.com|.+\.vercel\.app|.+\.netlify\.app|.+\.railway\.app|.+\.deno\.dev)$) {
            return 403;
        }

        resolver 1.1.1.1 8.8.8.8 ipv6=off valid=300s;
        resolver_timeout 5s;

        proxy_pass https://$proxy_target_host$proxy_target_path;
        proxy_ssl_server_name on;
        proxy_set_header Host $proxy_target_host;
        proxy_set_header User-Agent "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/130.0.0.0 Safari/537.36";
        proxy_set_header Authorization $http_x_harbor_auth;
        proxy_set_header Accept "application/json";

        proxy_buffering off;
        proxy_request_buffering off;
        proxy_read_timeout 60s;
        proxy_connect_timeout 30s;

        proxy_hide_header Set-Cookie;
        proxy_hide_header WWW-Authenticate;
    }

    location ~* \.(js|mjs|css|png|jpg|jpeg|gif|webp|svg|woff|woff2|ttf|ico)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    gzip on;
    gzip_vary on;
    gzip_types text/plain text/css text/javascript application/javascript application/json image/svg+xml;
}
