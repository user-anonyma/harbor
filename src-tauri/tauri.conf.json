{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harbor",
  "version": "0.9.36",
  "identifier": "app.harbor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Harbor",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "backgroundColor": [0, 0, 0, 255],
        "shadow": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "center": true,
        "additionalBrowserArgs": "--disk-cache-size=104857600 --media-cache-size=52428800 --autoplay-policy=no-user-gesture-required"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "deb", "rpm", "appimage", "nsis"],
    "externalBin": ["binaries/yt-dlp", "binaries/ffmpeg", "binaries/ffprobe"],
    "resources": {
      "fonts/*": "fonts/"
    },
    "licenseFile": "installer/eula.txt",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libmpv2 | libmpv1",
          "libwebkit2gtk-4.1-0",
          "libgl1",
          "libegl1",
          "libayatana-appindicator3-1",
          "libssl3",
          "ca-certificates",
          "gstreamer1.0-plugins-good",
          "gstreamer1.0-plugins-bad",
          "gstreamer1.0-libav"
        ]
      },
      "rpm": {
        "depends": [
          "mpv-libs",
          "webkit2gtk4.1",
          "mesa-libGL",
          "mesa-libEGL",
          "libappindicator-gtk3",
          "openssl-libs",
          "ca-certificates"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./installer-hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["harbor", "stremio"]
      }
    },
    "updater": {
      "endpoints": ["https://github.com/user-anonyma/harbor/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDQkE1MTAwRDgwNUZBRjUKUldUMStnWFlBRkc2N0pSbTh3d2ZWOUtkRnhSQWNDQVVwOWJ0amJxaXFReXRiOUpsT0hWWkYzbVUK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
